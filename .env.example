# Copy to `.env.local` and adjust. Never commit a real `.env` file — `.gitignore`
# blocks it and gitleaks scans for anything that slips through.
#
# Only variables prefixed with VITE_ are exposed to the browser bundle. Anything
# in here is therefore PUBLIC once the app is built. Never put a secret in this
# file or in any VITE_ variable.

# Placeholder: the app does not call zarlania-api yet. When it does, point this
# at the API base URL — http://localhost:8080 locally, or the Render service URL
# in production.
VITE_API_URL=http://localhost:8080
