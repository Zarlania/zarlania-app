server {
    listen       ${PORT};
    server_name  _;
    root         /usr/share/nginx/html;
    index        index.html;

    location / {
        # `/` is served by the prerendered index.html via the `index` directive
        # ($uri/ match). Client-rendered routes (/signup, /login, /home, unknown
        # paths) fall back to the CSR app shell so they are not served the
        # prerendered landing markup.
        try_files $uri $uri/ /index.csr.html;
    }
}
